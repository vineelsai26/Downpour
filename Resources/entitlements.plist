<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      This app is intentionally NOT sandboxed: it needs to read the iCloud Drive
      mirror and write to arbitrary external volumes, which the App Sandbox would
      block. Distribution is local/self-signed, so these entitlements are mostly
      relevant if you later enable the hardened runtime.
    -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
